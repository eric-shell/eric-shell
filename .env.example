# Resend API key for the /api/contact serverless function.
# Get one at https://resend.com/api-keys and set it here for local `vercel dev`,
# and in Vercel project settings (Production + Preview + Development) for deploys.
RESEND_API_KEY=

# Groq API key for the /api/chat serverless function (free tier).
# Get one at https://console.groq.com/keys and set it here for local `vercel dev`,
# and in Vercel project settings (Production + Preview + Development) for deploys.
GROQ_API_KEY=
